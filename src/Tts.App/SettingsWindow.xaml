<Window x:Class="Tts.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speech-to-Text Daemon Settings"
        Width="720"
        Height="560"
        MinWidth="600"
        MinHeight="500"
        Icon="Assets/speech-to-text-daemon.ico"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Speech-to-Text Daemon"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Configuration" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Config version" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding ConfigVersion}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" Text="Config file" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding ConfigPath}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" Text="Transcription provider" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SelectedTranscriptionProviderId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,0" Text="Output providers" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EnabledOutputProviders, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Hotkeys" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Start / Stop" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding StartStopHotkey, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" Text="Cancel" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CancelHotkey, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Audio And Cleanup" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Microphone device ID" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SelectedMicrophoneDeviceId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" Text="Cleanup" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsCleanupEnabled}" Content="Enabled" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,0" Text="Cleanup prompt" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 MinHeight="80"
                                 Text="{Binding CleanupPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding OpenSettingsFolderCommand}" Content="Open Folder" />
                <Button Margin="0,0,8,0" Padding="12,6" Click="OnHideToTrayClicked" Content="Hide To Tray" />
                <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding SaveCommand}" Content="Save" />
                <Button Padding="12,6" Click="OnQuitClicked" Content="Quit" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>