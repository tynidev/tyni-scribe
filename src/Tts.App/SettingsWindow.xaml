<Window x:Class="Tts.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speech-to-Text Daemon Settings"
        Width="720"
        SizeToContent="Height"
        MinWidth="600"
        MinHeight="500"
        Icon="Assets/speech-to-text-daemon.ico"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Speech-to-Text Daemon"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Configuration" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Config version" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding ConfigVersion}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" Text="Config file" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding ConfigPath}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" Text="Transcription provider" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding TranscriptionProviders}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedTranscriptionProviderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" Text="Audio processor" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SelectedAudioProcessorProviderId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,0,12,8"
                                   Text="Whisper model"
                                   Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding TranscriptionModels}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedWhisperCppModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,0,12,8"
                                   Text="Language"
                                   Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Margin="0,0,0,8"
                                 Text="{Binding TranscriptionLanguage, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,12,8"
                                   Text="Timeout seconds"
                                   Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Margin="0,0,0,8"
                                 Text="{Binding TranscriptionTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsWhisperCppProviderSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,12,0" Text="Output providers" />
                        <TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,8" Text="{Binding EnabledOutputProviders, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,12,8" Text="Session state" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SessionState}" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,12,8" Text="Session status" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SessionStatus}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,0,12,0" Text="Hotkey status" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding HotkeyStatus}" TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Hotkeys" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Start / Stop" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding StartStopHotkey, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" Text="Cancel" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CancelHotkey, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Audio And Cleanup" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" Text="Microphone" />
                        <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding MicrophoneDevices}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedMicrophoneDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="12,4"
                                    Command="{Binding RefreshMicrophonesCommand}"
                                    Content="Refresh" />
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" Text="Input level" />
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0"
                                         Height="16"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="{Binding MicrophoneLevel}" />
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding MicrophoneLevelText}" />
                            <Button Grid.Column="2"
                                    Padding="12,4"
                                    Command="{Binding ToggleLevelMonitoringCommand}"
                                    Content="{Binding LevelMonitoringButtonText}" />
                        </Grid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" Text="Microphone status" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding MicrophoneStatus}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" Text="Cleanup" />
                        <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsCleanupEnabled}" Content="Enabled" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,0" Text="Cleanup prompt" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 MinHeight="80"
                                 Text="{Binding CleanupPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding OpenSettingsFolderCommand}" Content="Open Folder" />
                <Button Margin="0,0,8,0" Padding="12,6" Click="OnHideToTrayClicked" Content="Hide To Tray" />
                <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding SaveCommand}" Content="Save" />
                <Button Padding="12,6" Click="OnQuitClicked" Content="Quit" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>